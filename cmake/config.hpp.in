#pragma once

#include <cstddef>
#include <cstdint>

#define AXI_TB_NUM_PORTS @AXI_TB_NUM_AXI@
#define AXI_TB_ADDRESS_BITS @AXI_TB_ADDR_WIDTH@
#define AXI_TB_DATA_BITS @AXI_TB_DATA_WIDTH@
#define AXI_TB_ID_BITS @AXI_TB_ID_WIDTH@
#define AXI_TB_THREADS @AXI_TB_THREADS@

#define AXI_TB_ROM_BASE UINT64_C(@AXI_TB_ROM_BASE@)
#define AXI_TB_ROM_SIZE UINT64_C(@AXI_TB_ROM_SIZE@)
#define AXI_TB_RAM_BASE UINT64_C(@AXI_TB_RAM_BASE@)
#define AXI_TB_RAM_SIZE UINT64_C(@AXI_TB_RAM_SIZE@)
#define AXI_TB_UART_BASE UINT64_C(@AXI_TB_UART_BASE@)
#define AXI_TB_UART_SIZE UINT64_C(@AXI_TB_UART_SIZE@)
#define AXI_TB_EXIT_BASE UINT64_C(@AXI_TB_EXIT_BASE@)
#define AXI_TB_EXIT_SIZE UINT64_C(@AXI_TB_EXIT_SIZE@)

#define AXI_TB_TRACE_ENABLED @AXI_TB_TRACE_ENABLED@
#define AXI_TB_TRACE_FST_ENABLED @AXI_TB_TRACE_FST_ENABLED@

namespace axi_tb::config {

inline constexpr std::size_t NUM_PORTS = AXI_TB_NUM_PORTS;
inline constexpr std::size_t ADDRESS_BITS = AXI_TB_ADDRESS_BITS;
inline constexpr std::size_t DATA_BITS = AXI_TB_DATA_BITS;
inline constexpr std::size_t DATA_BYTES = DATA_BITS / 8U;
inline constexpr std::size_t ID_BITS = AXI_TB_ID_BITS;
inline constexpr unsigned THREADS = AXI_TB_THREADS;

inline constexpr std::uint64_t ROM_BASE = AXI_TB_ROM_BASE;
inline constexpr std::uint64_t ROM_SIZE = AXI_TB_ROM_SIZE;
inline constexpr std::uint64_t RAM_BASE = AXI_TB_RAM_BASE;
inline constexpr std::uint64_t RAM_SIZE = AXI_TB_RAM_SIZE;
inline constexpr std::uint64_t UART_BASE = AXI_TB_UART_BASE;
inline constexpr std::uint64_t UART_SIZE = AXI_TB_UART_SIZE;
inline constexpr std::uint64_t EXIT_BASE = AXI_TB_EXIT_BASE;
inline constexpr std::uint64_t EXIT_SIZE = AXI_TB_EXIT_SIZE;

inline constexpr bool TRACE_ENABLED = AXI_TB_TRACE_ENABLED != 0;
inline constexpr bool TRACE_FST_ENABLED = AXI_TB_TRACE_FST_ENABLED != 0;

static_assert(NUM_PORTS > 0);
static_assert(ADDRESS_BITS == 32 || ADDRESS_BITS == 64);
static_assert(DATA_BITS == 32 || DATA_BITS == 64 || DATA_BITS == 128);
static_assert(ID_BITS >= 1 && ID_BITS <= 32);
static_assert(THREADS > 0);

}  // namespace axi_tb::config
